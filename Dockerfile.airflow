FROM apache/airflow:2.10.3

USER root
RUN apt-get update && apt-get install -y openjdk-17-jre-headless curl && apt-get clean
ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64

# JARs for spark-submit driver (client mode)
RUN mkdir -p /opt/spark-jars && cd /opt/spark-jars && \
    curl -sLO https://repo1.maven.org/maven2/org/apache/hadoop/hadoop-aws/3.3.4/hadoop-aws-3.3.4.jar && \
    curl -sLO https://repo1.maven.org/maven2/com/amazonaws/aws-java-sdk-bundle/1.12.262/aws-java-sdk-bundle-1.12.262.jar && \
    curl -sLO https://repo1.maven.org/maven2/org/apache/iceberg/iceberg-spark-runtime-3.5_2.12/1.5.0/iceberg-spark-runtime-3.5_2.12-1.5.0.jar && \
    curl -sLO https://repo1.maven.org/maven2/org/projectnessie/nessie-integrations/nessie-spark-extensions-3.5_2.12/0.77.1/nessie-spark-extensions-3.5_2.12-0.77.1.jar && \
    curl -sLO https://repo1.maven.org/maven2/software/amazon/awssdk/bundle/2.24.8/bundle-2.24.8.jar && \
    curl -sLO https://repo1.maven.org/maven2/software/amazon/awssdk/url-connection-client/2.24.8/url-connection-client-2.24.8.jar

USER airflow

RUN pip install --no-cache-dir \
    apache-airflow-providers-apache-spark==4.1.3 \
    pyspark==3.5.5 \
    s3fs \
    "dlt[filesystem]" \
    pandas \
    pyarrow \
    boto3 \
    requests
